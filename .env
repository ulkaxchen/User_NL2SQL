# 复制本文件为项目根目录下的 .env 并填写；后端会在导入时自动加载（无需手动 export）。
# cp .env.example .env

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
# 必填：业务表所在库名（未设置时表列表为空）
MYSQL_DATABASE=rag_db

# 可选：与 USER_RAG_* 等价，二选一即可
# USER_RAG_MYSQL_HOST=127.0.0.1
# USER_RAG_MYSQL_DATABASE=your_database_name
